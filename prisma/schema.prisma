// schema.prisma
generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String        @id @default(uuid())
  name          String
  email         String        @unique
  // 🔒 CRITICAL: Tracks if email is verified. Auth.js populates this automatically via Google 
  // or via Magic Links. Classic signups stay unverified until authenticated.
  emailVerified DateTime?     
  password      String?       // Made optional because Google OAuth accounts won't have a password string
  image         String?       // Stores profile image links from Google profiles automatically
  
  // Auth.js structural session relation bridges
  accounts      Account[]
  sessions      Session[]
  
  // Your existing relational linkages preserved perfectly
  diaries       Diary[]       @relation("UserDiaries")
  entries       Entry[]
  reactions     Reaction[]
  joinRequests  JoinRequest[] 
  createdAt     DateTime      @default(now())
}

// 🏢 New Model required by Auth.js to map OAuth tokens (Google tokens, refresh tokens, etc.) securely
model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// ⏳ New Model required by Auth.js to handle secure active state sessions
model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ✉️ New Model required by Auth.js to handle temporary email token links (Magic Verification Pins)
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Diary {
  id           String        @id @default(uuid())
  title        String
  inviteCode   String        @unique
  creatorId    String?       
  nudgeDays    Int           @default(3)
  users        User[]        @relation("UserDiaries")
  entries      Entry[]
  joinRequests JoinRequest[] 
  createdAt    DateTime      @default(now())
}

model JoinRequest {
  id        String   @id @default(uuid())
  diaryId   String
  diary     Diary    @relation(fields: [diaryId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String   
  createdAt DateTime @default(now())

  @@unique([diaryId, userId]) 
}

model Entry {
  id         String     @id @default(uuid())
  diaryId    String
  diary      Diary      @relation(fields: [diaryId], references: [id], onDelete: Cascade)
  authorId   String
  author     User       @relation(fields: [authorId], references: [id])
  title      String
  content    String     @db.Text
  imageUrl   String?
  isCapsule  Boolean    @default(false)
  unlockDate DateTime?
  reactions  Reaction[]
  createdAt  DateTime   @default(now())
}

model Reaction {
  id        String   @id @default(uuid())
  entryId   String
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  emoji     String   
  createdAt DateTime @default(now())
}